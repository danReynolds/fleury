---
// Embeds a live, client-side Fleury widget. The widget identified by `id` is
// mounted from the dart2js examples bundle (public/fleury-examples.js) into a
// host sized to a cell grid (cols × rows). A header bar marks it as a live,
// interactive example; the "Expand" button re-mounts it fullscreen.
interface Props {
  /** Registry id, e.g. "gauge.basic" (see website/examples/lib/registry.dart). */
  id: string;
  /** Optional caption shown above the example. */
  title?: string;
  /** Grid width in character cells. */
  cols?: number;
  /** Grid height in rows. */
  rows?: number;
}
const { id, title, cols = 60, rows = 12 } = Astro.props;
// ch ≈ one monospace column; 1 row = line-height (1.25) em at the host font size.
const style = `width:${cols}ch;height:${(rows * 1.25).toFixed(2)}em`;
---

<figure class="fleury-example">
  {title && <figcaption>{title}</figcaption>}
  <div class="fleury-frame">
    <div class="fleury-bar">
      <span
        class="fleury-badge"
        title="The real widget, running live in your browser (compiled with dart2js) — click it and use your keyboard/mouse to interact."
      >
        <span class="fleury-dot"></span>Live · interactive
      </span>
      <button
        class="fleury-expand"
        type="button"
        data-id={id}
        data-cols={cols}
        data-rows={rows}
        aria-label="Expand this example to full screen"
      >⛶ Expand</button>
    </div>
    <div class="fleury-host-wrap">
      <div
        class="fleury-host"
        data-fleury-example={id}
        style={style}
        role="img"
        aria-label={title ?? `Live Fleury example: ${id}`}
      >
      </div>
    </div>
  </div>
</figure>

<script is:inline>
  (function () {
    if (window.__fleuryExamplesBoot) return;
    window.__fleuryExamplesBoot = true;

    if (!document.getElementById('fleury-examples-bundle')) {
      const s = document.createElement('script');
      s.id = 'fleury-examples-bundle';
      s.src = '/fleury-examples.js';
      s.defer = true;
      document.head.appendChild(s);
    }
    document.addEventListener('astro:page-load', () => {
      if (window.fleuryMountExamples) window.fleuryMountExamples();
    });

    function expand(id, cols, rows) {
      const fc = Math.min(Math.round(cols * 1.5), 160);
      const fr = Math.min(Math.round(rows * 1.4), 46);
      const overlay = document.createElement('div');
      overlay.className = 'fleury-overlay';
      const card = document.createElement('div');
      card.className = 'fleury-overlay-card';
      const bar = document.createElement('div');
      bar.className = 'fleury-overlay-bar';
      const close = document.createElement('button');
      close.type = 'button';
      close.className = 'fleury-overlay-close';
      close.textContent = '✕ Close (Esc)';
      bar.appendChild(close);
      const host = document.createElement('div');
      host.className = 'fleury-host';
      host.style.cssText =
        `width:${fc}ch;height:${(fr * 1.25).toFixed(1)}em;max-width:92vw;max-height:78vh`;
      card.appendChild(bar);
      card.appendChild(host);
      overlay.appendChild(card);
      document.body.appendChild(overlay);
      document.documentElement.style.overflow = 'hidden';

      const handle = window.fleuryMountInto
        ? window.fleuryMountInto(host, id)
        : null;
      const dismiss = () => {
        if (handle && handle.dispose) handle.dispose();
        overlay.remove();
        document.documentElement.style.overflow = '';
        document.removeEventListener('keydown', onKey);
      };
      const onKey = (e) => {
        if (e.key === 'Escape') dismiss();
      };
      document.addEventListener('keydown', onKey);
      overlay.addEventListener('mousedown', (e) => {
        if (e.target === overlay) dismiss();
      });
      close.addEventListener('click', dismiss);
    }

    document.addEventListener('click', (e) => {
      const btn = e.target.closest && e.target.closest('.fleury-expand');
      if (!btn) return;
      expand(btn.dataset.id, +btn.dataset.cols, +btn.dataset.rows);
    });
  })();
</script>

<style>
  .fleury-example {
    margin: 1.5rem 0;
  }
  .fleury-example figcaption {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.4rem;
  }
  .fleury-frame {
    display: inline-block;
    max-width: 100%;
    overflow: hidden;
    background: #0b0f14;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
  }
  .fleury-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.3rem 0.6rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    background: rgba(255, 255, 255, 0.025);
  }
  .fleury-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
    cursor: help;
  }
  .fleury-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #3ddc97;
    animation: fleury-pulse 1.8s ease-out infinite;
  }
  @keyframes fleury-pulse {
    0% { box-shadow: 0 0 0 0 rgba(61, 220, 151, 0.5); }
    70% { box-shadow: 0 0 0 5px rgba(61, 220, 151, 0); }
    100% { box-shadow: 0 0 0 0 rgba(61, 220, 151, 0); }
  }
  .fleury-expand {
    background: transparent;
    color: var(--sl-color-gray-2);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.35rem;
    padding: 0.1rem 0.5rem;
    font-size: 0.74rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .fleury-expand:hover {
    color: #fff;
    border-color: var(--sl-color-gray-4);
  }
  .fleury-host-wrap {
    padding: 0.75rem 1rem;
    overflow: auto;
    max-width: 100%;
  }
  .fleury-host {
    font-family: var(--sl-font-mono, ui-monospace, monospace);
    font-size: 14px;
    line-height: 1.25;
    color: #c8d3e0;
  }
</style>

<style is:global>
  /* Runtime-created grid rows: reset Starlight's between-block margin so a row
     is exactly one line tall (else every example double-spaces + overflows). */
  .fleury-host .fleury-screen,
  .fleury-host .fleury-row,
  .fleury-host .fleury-semantics {
    margin: 0 !important;
  }

  /* Fullscreen overlay (appended to <body>, so it needs global styles). */
  .fleury-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.72);
  }
  .fleury-overlay-card {
    max-width: 95vw;
    max-height: 90vh;
    overflow: auto;
    padding: 0.5rem 1rem 1rem;
    background: #0b0f14;
    border: 1px solid var(--sl-color-gray-4, #4a4a4a);
    border-radius: 0.6rem;
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.55);
  }
  .fleury-overlay-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.5rem;
  }
  .fleury-overlay-close {
    background: transparent;
    color: var(--sl-color-gray-2, #cbd2da);
    border: 1px solid var(--sl-color-gray-5, #555);
    border-radius: 0.4rem;
    padding: 0.25rem 0.65rem;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .fleury-overlay-close:hover {
    color: #fff;
    border-color: #888;
  }
</style>
