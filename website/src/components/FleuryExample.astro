---
// Embeds a live, client-side Fleury widget. The widget identified by `id` is
// mounted from the dart2js examples bundle (public/fleury-examples.js) into a
// host sized to a cell grid (cols × rows). A header bar marks it as live; the
// badge says "interactive" only when the widget actually responds to input
// (see ExampleInfo.interactive in registry.dart). The "Expand" button re-mounts
// it fullscreen. Shared styling lives in src/styles/fleury.css (site-wide).
interface Props {
  /** Registry id, e.g. "gauge.basic" (see website/examples/lib/registry.dart). */
  id: string;
  /** Optional caption shown above the example. */
  title?: string;
  /** Grid width in character cells. */
  cols?: number;
  /** Grid height in rows. */
  rows?: number;
  /** Whether the widget responds to keyboard/mouse input. */
  interactive?: boolean;
  /** Visual theme for the embedded widget. `site` follows Starlight light/dark. */
  surfaceTheme?: 'dark' | 'light' | 'site';
}
const {
  id,
  title,
  cols = 60,
  rows = 12,
  interactive = false,
  surfaceTheme = 'dark',
} = Astro.props;
// ch ≈ one monospace column; 1 row = line-height (1.25) em at the host font size.
const style = `width:${cols}ch;height:${(rows * 1.25).toFixed(2)}em`;
const badgeLabel = interactive ? 'Live · interactive' : 'Live';
const badgeTitle = interactive
  ? 'The real widget, running live in your browser (dart2js) — click it and use your keyboard/mouse to interact.'
  : 'The real widget, running live in your browser, compiled with dart2js.';
---

<figure class="fleury-example">
  {title && <figcaption>{title}</figcaption>}
  <div class="fleury-frame" data-fleury-theme={surfaceTheme}>
    <div class="fleury-bar">
      <span class="fleury-badge" title={badgeTitle}>
        <span class="fleury-dot"></span>{badgeLabel}
      </span>
      <div style="display:flex;align-items:center;gap:0.6rem">
        {interactive && <span class="fleury-hint">click &amp; type to interact</span>}
        <a
          class="fleury-info"
          href="/architecture/serving-and-embedding/"
          title="The real widget, running live in your browser — compiled to JavaScript with dart2js, no server. Click to learn how."
        >ⓘ how it works</a>
        <button
          class="fleury-expand"
          type="button"
          data-id={id}
          data-cols={cols}
          data-rows={rows}
          data-theme={surfaceTheme}
          aria-label="Expand this example to full screen"
        >⛶ Expand</button>
      </div>
    </div>
    <div class="fleury-host-wrap">
      <div
        class="fleury-host"
        data-fleury-example={id}
        data-fleury-theme={surfaceTheme}
        style={style}
        role="img"
        aria-label={title ?? `Live Fleury example: ${id}`}
      >
      </div>
    </div>
  </div>
</figure>

<script is:inline>
  (function () {
    if (window.__fleuryExamplesBoot) return;
    window.__fleuryExamplesBoot = true;

    if (!document.getElementById('fleury-examples-bundle')) {
      const s = document.createElement('script');
      s.id = 'fleury-examples-bundle';
      s.src = '/fleury-examples.js';
      s.defer = true;
      document.head.appendChild(s);
    }
    document.addEventListener('astro:page-load', () => {
      if (window.fleuryMountExamples) window.fleuryMountExamples();
    });

    function expand(id, cols, rows, theme) {
      const fc = Math.min(Math.round(cols * 1.5), 160);
      const fr = Math.min(Math.round(rows * 1.4), 46);
      const overlay = document.createElement('div');
      overlay.className = 'fleury-overlay';
      const card = document.createElement('div');
      card.className = 'fleury-overlay-card';
      card.dataset.fleuryTheme = theme || 'dark';
      const bar = document.createElement('div');
      bar.className = 'fleury-overlay-bar';
      const close = document.createElement('button');
      close.type = 'button';
      close.className = 'fleury-overlay-close';
      close.textContent = '✕ Close (Esc)';
      bar.appendChild(close);
      const host = document.createElement('div');
      host.className = 'fleury-host';
      host.dataset.fleuryTheme = theme || 'dark';
      host.style.cssText =
        `width:${fc}ch;height:${(fr * 1.25).toFixed(1)}em;max-width:92vw;max-height:78vh`;
      card.appendChild(bar);
      card.appendChild(host);
      overlay.appendChild(card);
      document.body.appendChild(overlay);
      document.documentElement.style.overflow = 'hidden';

      const handle = window.fleuryMountInto
        ? window.fleuryMountInto(host, id)
        : null;
      const dismiss = () => {
        if (handle && handle.dispose) handle.dispose();
        overlay.remove();
        document.documentElement.style.overflow = '';
        document.removeEventListener('keydown', onKey);
      };
      const onKey = (e) => {
        if (e.key === 'Escape') dismiss();
      };
      document.addEventListener('keydown', onKey);
      overlay.addEventListener('mousedown', (e) => {
        if (e.target === overlay) dismiss();
      });
      close.addEventListener('click', dismiss);
    }

    document.addEventListener('click', (e) => {
      const btn = e.target.closest && e.target.closest('.fleury-expand');
      if (!btn) return;
      expand(btn.dataset.id, +btn.dataset.cols, +btn.dataset.rows, btn.dataset.theme);
    });
  })();
</script>
